@be_HostAddress = http://localhost:5000
@accessToken = paste-login-access-token-here

GET {{be_HostAddress}}/weatherforecast/
Accept: application/json

###

GET {{be_HostAddress}}/api/message
Accept: text/plain

###

POST {{be_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@example.local",
  "password": "Admin123!"
}

###

GET {{be_HostAddress}}/api/auth/me
Authorization: Bearer {{accessToken}}
Accept: application/json

###

GET {{be_HostAddress}}/api/auth/admin-check
Authorization: Bearer {{accessToken}}
Accept: application/json

###

GET {{be_HostAddress}}/api/database-overview
Authorization: Bearer {{accessToken}}
Accept: application/json

###

GET {{be_HostAddress}}/api/admin/project-task-report
Authorization: Bearer {{accessToken}}
Accept: application/json

###
